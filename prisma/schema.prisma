generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// Options to chooose from for a role
enum Role {
  STUDENT
  RECRUITER
  EXPLORER
  ADMIN
}

model User {
  id String @id @default(cuid())
  email String @unique
  name String
  dateofBirth DateTime?
  hashedPassword String?
  role Role @default(EXPLORER)
  skills String[]

  resetToken String?
  resetTokenExpiry DateTime?

  college String?
  resumeLink String?
  resumeUrl String?
  githubUrl String?
  linkedinUrl String?
  portfolioUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}